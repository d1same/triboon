<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Triboon is self-hosted and IPTV providers commonly remain HTTP-only.
         Cleartext is explicit here instead of relying on platform defaults. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
