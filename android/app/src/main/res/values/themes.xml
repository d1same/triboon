<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Ink-black (matches the web UI's ink color #0B0812), no flash of white. Immersive
         fullscreen is applied at runtime in applySystemUiPolicy() — TV always, and phones only
         while a video is fullscreen. The theme must NOT force .Fullscreen, or the phone status
         bar would be suppressed at window inflation before the runtime (TV-only) flags run. -->
    <style name="TriboonTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
