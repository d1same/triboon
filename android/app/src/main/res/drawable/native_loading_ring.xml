<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="ring"
            android:innerRadiusRatio="2.9"
            android:thickness="2dp"
            android:useLevel="false">
            <solid android:color="#18F3EFF7" />
            <size android:width="124dp" android:height="124dp" />
        </shape>
    </item>
    <item>
        <rotate
            android:fromDegrees="0"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="360">
            <shape android:shape="ring"
                android:innerRadiusRatio="2.9"
                android:thickness="3dp"
                android:useLevel="false">
                <gradient
                    android:type="sweep"
                    android:startColor="#00FB8B3C"
                    android:centerColor="#FB8B3C"
                    android:endColor="#FFC65C"
                    android:useLevel="false" />
                <size android:width="124dp" android:height="124dp" />
            </shape>
        </rotate>
    </item>
</layer-list>
