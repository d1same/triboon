{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Triboon PX8",
  "version": "0.1.0",
  "identifier": "app.triboon.px8",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Triboon",
        "width": 1280,
        "height": 800,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "url": "connect.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
