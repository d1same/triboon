# Runtime state — contains encrypted credentials, user data, caches, and signed tokens.
# NEVER commit.
data/
node_modules/
.env
.env.*
!.env.example
cookies.txt
*.cookies.txt
*cookies*.txt
gitleaks-report*.json
gitleaks-*.json

# Local demo/debug artifacts: admin tokens, personal NZBs, play payloads, and REAL MEDIA
# folders used for library-scan testing. Only the credential-free mock server is tracked.
demo/*
!demo/mock-xtream.js

# Local machine settings (approved commands with environment specifics, launch configs).
.claude/
AGENTS.md
android/.idea/
android/gradle/gradle-daemon-jvm.properties
test/fixtures/work/

# Local-only debug/bench material stays private, but the sanitized release gates are deliberately
# tracked so package.json works from a clean clone.
bench/
!bench/
bench/*
!bench/verify-before-update.ps1
!bench/verify-live.js
!bench/cut-apk-release.ps1
!bench/android-tv-stress.ps1
!bench/android-tv-smoke.ps1
docs-release-audit.md

# Android: machine-local SDK path, build outputs, gradle caches, built APKs, signing keys.
android/local.properties
android/.gradle/
android/build/
android/app/build/
*.apk
*.keystore
*.jks
*.pem
*.key
*.p12

# Test/debug scratch output (server logs can echo release names and channel lists).
dist/
tmp/
*.log
alltests.txt
p2fail*.txt
graphify-out/
.codex-remote-attachments/
